# API origin only (no trailing /api). Used by login, session, and all dashboards.
VITE_API_URL=http://localhost:5100
# Standalone Shule Teacher portal (Lite-school teachers). Origin only, no trailing slash.
# Teacher portal (public header link). Production: https://ticha.babyeyi.rw
# VITE_TEACHER_PORTAL_URL=https://ticha.babyeyi.rw
# Babyeyi verify / QR link origin (optional; defaults to current app origin, e.g. http://localhost:5173)
# VITE_BABYEYI_VERIFY_PUBLIC_URL=http://localhost:5173
# Production: VITE_BABYEYI_VERIFY_PUBLIC_URL=https://babyeyi.rw
# Unified Pro web (babyeyipro). Origin only.
# VITE_PRO_APP_URL=http://localhost:5174
# Optional legacy alias — prefer VITE_API_URL. If set, may include /api suffix.
# VITE_API_BASE=http://localhost:5100/api
