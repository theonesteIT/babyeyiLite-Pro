NODE_ENV=development
PORT=5100

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=school_db

SESSION_SECRET=replace-with-long-random-secret
BABYEYI_HASH_SECRET=replace-with-long-random-secret

FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ---------------------------------------------------------------------------
# Email — fee reminders (accountant), parent emails, invoices
# Gmail: use an App Password (not your normal password) for SMTP_PASS
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=fees@your-school.com
SMTP_PASS=your-smtp-app-password-here
SMTP_FROM="School Fees" <fees@your-school.com>

# ---------------------------------------------------------------------------
# Web Push / VAPID — accountant portal + parent portal (same keys for both)
# Generate: cd BabyeyiSystem/backend && node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)"
# VAPID_SUBJECT should be mailto:your-contact@domain (often same as SMTP_USER)
# ---------------------------------------------------------------------------
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:fees@your-school.com
