NODE_ENV=development
PORT=5100

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=school_db

SESSION_SECRET=replace-with-long-random-secret
BABYEYI_HASH_SECRET=replace-with-long-random-secret

FRONTEND_URL=http://localhost:5173
# Base URL encoded in student report QR codes (defaults to FRONTEND_URL)
PUBLIC_REPORT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ---------------------------------------------------------------------------
# Email — fee reminders (accountant), parent emails, invoices
# Gmail: use an App Password (not your normal password) for SMTP_PASS
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=fees@your-school.com
SMTP_PASS=your-smtp-app-password-here
SMTP_FROM="School Fees" <fees@your-school.com>

# ---------------------------------------------------------------------------
# Web Push / VAPID — accountant portal + parent portal (same keys for both)
# Generate keys — see docs/WEB_PUSH_VAPID.md
# cd BabyeyiSystem/backend && node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)"
# VAPID_SUBJECT should be mailto:your-contact@domain (often same as SMTP_USER)
# ---------------------------------------------------------------------------
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:fees@your-school.com

# ---------------------------------------------------------------------------
# Optional — node scripts/add-super-admins.js (never commit real passwords)
# JSON array: email, password, first_name, last_name per account
# EXTRA_SUPER_ADMINS=[{"email":"admin2@example.com","password":"change-me","first_name":"Super","last_name":"Admin Two"}]
# ---------------------------------------------------------------------------
# EXTRA_SUPER_ADMINS=

# ---------------------------------------------------------------------------
# Optional — node scripts/bootstrap-st-theo-school.js (never commit real passwords)
# BOOTSTRAP_SCHOOL_ADMIN_EMAIL=admin@your-school.com
# BOOTSTRAP_SCHOOL_ADMIN_PASSWORD=change-me
# BOOTSTRAP_SCHOOL_NAME=St Theo School
# BOOTSTRAP_SCHOOL_PROVINCE=Kigali City
# BOOTSTRAP_SCHOOL_DISTRICT=Gasabo
# BOOTSTRAP_SCHOOL_SECTOR=Remera
# BOOTSTRAP_SCHOOL_PHONE=0780000000
# ---------------------------------------------------------------------------
