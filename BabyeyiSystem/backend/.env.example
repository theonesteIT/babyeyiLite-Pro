NODE_ENV=development
PORT=5100

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=school_db

SESSION_SECRET=replace-with-long-random-secret
BABYEYI_HASH_SECRET=replace-with-long-random-secret

FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
# QR codes and verify links on printed Babyeyi documents (production: https://babyeyi.rw)
# BABYEYI_VERIFY_PUBLIC_ORIGIN=https://babyeyi.rw

# ── MTN MoMo Collection (public payments.jsx + TichaDeals pay) ───────────────
# Same names as momoRoutes.js — either MTN_MOMO_* or MOMO_* prefix works.
# MOMO_BASE_URL=https://proxy.momoapi.mtn.co.rw
# MOMO_SUBSCRIPTION_KEY=
# MOMO_API_USER_ID=
# MOMO_API_KEY=
# MOMO_ENVIRONMENT=mtnrwanda

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generate a fresh pair with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2))"
# VAPID_SUBJECT must be either a mailto: address or your site URL.
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:admin@yourdomain.com
