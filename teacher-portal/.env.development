# Teacher portal dev → same Babyeyi API as public payments (MTN keys in BabyeyiSystem/backend/.env)
# Leave VITE_API_URL empty: browser calls /api; Vite proxies to VITE_PROXY_TARGET (see vite.config.js).
# If your Babyeyi server uses another port, set: VITE_PROXY_TARGET=http://localhost:YOUR_PORT
# Or call the API directly: VITE_API_URL=http://localhost:5100
VITE_API_URL=
VITE_PROXY_TARGET=http://localhost:5100
